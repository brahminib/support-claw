# Support Claw .env example
#
# Support Claw is built on the SupportClaw runtime, so the underlying environment
# variable names still use the SUPPORT_CLAW_ prefix. Keep those names unless the
# implementation layer is changed too.
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.supportClaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.supportClaw/.env, then supportClaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in supportClaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Required if the gateway binds beyond loopback. Leave blank to have SupportClaw
# auto-generate a token on first start, or provide your own using
# `openssl rand -hex 32`. The gateway will refuse to start if this is set to
# the documented example placeholder, so never copy-paste an example value
# from docs or tutorials into this file verbatim.
SUPPORT_CLAW_GATEWAY_TOKEN=

# Optional alternative auth mode (use token OR password).
# SUPPORT_CLAW_GATEWAY_PASSWORD=

# Optional path overrides (defaults shown for reference).
# SUPPORT_CLAW_STATE_DIR=~/.supportClaw
# SUPPORT_CLAW_CONFIG_PATH=~/.supportClaw/supportClaw.json
# SUPPORT_CLAW_HOME=~
# Docker setup stores auth profile encryption key material outside the mounted
# SupportClaw state dir and mounts this host directory into the container.
# SUPPORT_CLAW_AUTH_PROFILE_SECRET_DIR=/absolute/path/to/.supportClaw-auth-profile-secrets

# Allowlist of extra directories that `$include` directives in supportClaw.json may
# resolve files from. Path-list separated (':' on POSIX, ';' on Windows). Each
# entry is tilde-expanded. Without this, `$include` is confined to the directory
# containing supportClaw.json.
# SUPPORT_CLAW_INCLUDE_ROOTS=/etc/supportClaw/shared:~/.supportClaw/shared

# Optional: import missing keys from your login shell profile.
# SUPPORT_CLAW_LOAD_SHELL_ENV=1
# SUPPORT_CLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# SUPPORT_CLAW_LIVE_OPENAI_KEY=sk-...
# SUPPORT_CLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# SUPPORT_CLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# TOKENHUB_API_KEY=...
# LKEAP_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# For a support assistant, start with one internal team channel such as Slack or
# Discord before enabling customer-facing channels.
#
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# SUPPORT_CLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# INWORLD_API_KEY=...
# DEEPGRAM_API_KEY=...
