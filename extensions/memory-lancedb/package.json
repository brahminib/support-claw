{
  "name": "@supportclaw/memory-lancedb",
  "version": "2026.6.9",
  "description": "SupportClaw LanceDB-backed long-term memory plugin with auto-recall, auto-capture, and vector search.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "0.30.0",
    "apache-arrow": "21.1.0",
    "openai": "6.39.1",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*"
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@supportclaw/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.31"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9"
    },
    "release": {
      "bundleRuntimeDependencies": false,
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
