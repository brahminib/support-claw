{
  "name": "@supportclaw/lobster",
  "version": "2026.6.9",
  "description": "Lobster workflow tool plugin for typed pipelines and resumable approvals.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "dependencies": {
    "@clawdbot/lobster": "2026.5.22",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*"
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@supportclaw/lobster",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
