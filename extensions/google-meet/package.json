{
  "name": "@supportclaw/google-meet",
  "version": "2026.6.9",
  "description": "SupportClaw Google Meet participant plugin for joining calls through Chrome or Twilio transports.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*",
    "supportClaw": "2026.5.28"
  },
  "peerDependencies": {
    "supportClaw": ">=2026.6.9"
  },
  "peerDependenciesMeta": {
    "supportClaw": {
      "optional": true
    }
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@supportclaw/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
