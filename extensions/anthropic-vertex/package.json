{
  "name": "@supportclaw/anthropic-vertex-provider",
  "version": "2026.6.9",
  "description": "SupportClaw Anthropic Vertex provider plugin for Claude models on Google Vertex AI.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "0.16.1"
  },
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*"
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@supportclaw/anthropic-vertex-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
