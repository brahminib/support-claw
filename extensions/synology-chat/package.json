{
  "name": "@supportclaw/synology-chat",
  "version": "2026.6.9",
  "description": "Synology Chat channel plugin for SupportClaw channels and direct messages.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*"
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to SupportClaw with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@supportclaw/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
