{
  "name": "@supportclaw/qqbot",
  "version": "2026.6.9",
  "private": false,
  "description": "SupportClaw QQ Bot channel plugin for group and direct-message workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "dependencies": {
    "@tencent-connect/qqbot-connector": "1.1.0",
    "mpg123-decoder": "1.0.3",
    "silk-wasm": "3.7.1",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*",
    "@types/ws": "8.18.1",
    "supportClaw": "2026.5.28"
  },
  "peerDependencies": {
    "supportClaw": ">=2026.6.9"
  },
  "peerDependenciesMeta": {
    "supportClaw": {
      "optional": true
    }
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "qqbot",
      "label": "QQ Bot",
      "selectionLabel": "QQ Bot (Official API)",
      "detailLabel": "QQ Bot",
      "docsPath": "/channels/qqbot",
      "docsLabel": "qqbot",
      "blurb": "connect to QQ via official QQ Bot API with group chat and direct message support.",
      "systemImage": "bubble.left.and.bubble.right"
    },
    "install": {
      "npmSpec": "@supportclaw/qqbot",
      "localPath": "extensions/qqbot",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
