{
  "name": "@supportclaw/codex",
  "version": "2026.6.9",
  "description": "SupportClaw Codex app-server harness and model provider plugin with a Codex-managed GPT catalog.",
  "repository": {
    "type": "git",
    "url": "https://github.com/brahminib/support-claw"
  },
  "type": "module",
  "dependencies": {
    "@openai/codex": "0.139.0",
    "typebox": "1.1.39",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@supportclaw/plugin-sdk": "workspace:*"
  },
  "supportClaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@supportclaw/codex",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.1-beta.1",
      "requiredPlatformPackages": [
        "@openai/codex-linux-x64",
        "@openai/codex-linux-arm64",
        "@openai/codex-darwin-x64",
        "@openai/codex-darwin-arm64",
        "@openai/codex-win32-x64",
        "@openai/codex-win32-arm64"
      ]
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "supportClawVersion": "2026.6.9"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true,
      "bundleRuntimeDependencies": false
    }
  }
}
