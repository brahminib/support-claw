// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

SUPPORT_CLAW_CODE_SIGN_STYLE = Manual
SUPPORT_CLAW_CODE_SIGN_IDENTITY = Apple Development
SUPPORT_CLAW_DEVELOPMENT_TEAM = FWJYW4S8P8

SUPPORT_CLAW_APP_BUNDLE_ID = ai.supportClawfoundation.app
SUPPORT_CLAW_SHARE_BUNDLE_ID = ai.supportClawfoundation.app.share
SUPPORT_CLAW_APP_GROUP_ID = group.ai.supportClawfoundation.app.shared
SUPPORT_CLAW_WATCH_APP_BUNDLE_ID = ai.supportClawfoundation.app.watchkitapp
SUPPORT_CLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.supportClawfoundation.app.activitywidget
SUPPORT_CLAW_APNS_ENTITLEMENT_ENVIRONMENT = development

SUPPORT_CLAW_APP_PROFILE = ai.supportClawfoundation.app Development
SUPPORT_CLAW_SHARE_PROFILE = ai.supportClawfoundation.app.share Development
SUPPORT_CLAW_ACTIVITY_WIDGET_PROFILE =
SUPPORT_CLAW_WATCH_APP_PROFILE =

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
